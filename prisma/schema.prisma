generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  pending
  paid
  shipped
  delivered
  cancelled
}

model Product {
  id          String   @id @default(uuid())

  name        String
  description String
  category    String
  imageUrls    String[]
  price       Float

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}